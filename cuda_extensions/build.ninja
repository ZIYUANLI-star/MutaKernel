ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda/bin/nvcc

cflags = -DTORCH_EXTENSION_NAME=log_softmax_cuda_cfgstress_mut_8efaa987b5 -DTORCH_API_INCLUDE_EXTENSION_H -DPYBIND11_COMPILER_TYPE=\"_gcc\" -DPYBIND11_STDLIB=\"_libstdcpp\" -DPYBIND11_BUILD_ABI=\"_cxxabi1011\" -isystem /home/kbuser/projects/KernelBench-0/.venv/lib/python3.10/site-packages/torch/include -isystem /home/kbuser/projects/KernelBench-0/.venv/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -isystem /home/kbuser/projects/KernelBench-0/.venv/lib/python3.10/site-packages/torch/include/TH -isystem /home/kbuser/projects/KernelBench-0/.venv/lib/python3.10/site-packages/torch/include/THC -isystem /usr/local/cuda/include -isystem /usr/include/python3.10 -D_GLIBCXX_USE_CXX11_ABI=0 -fPIC -std=c++17
post_cflags = 
cuda_cflags = -DTORCH_EXTENSION_NAME=log_softmax_cuda_cfgstress_mut_8efaa987b5 -DTORCH_API_INCLUDE_EXTENSION_H -DPYBIND11_COMPILER_TYPE=\"_gcc\" -DPYBIND11_STDLIB=\"_libstdcpp\" -DPYBIND11_BUILD_ABI=\"_cxxabi1011\" -isystem /home/kbuser/projects/KernelBench-0/.venv/lib/python3.10/site-packages/torch/include -isystem /home/kbuser/projects/KernelBench-0/.venv/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -isystem /home/kbuser/projects/KernelBench-0/.venv/lib/python3.10/site-packages/torch/include/TH -isystem /home/kbuser/projects/KernelBench-0/.venv/lib/python3.10/site-packages/torch/include/THC -isystem /usr/local/cuda/include -isystem /usr/include/python3.10 -D_GLIBCXX_USE_CXX11_ABI=0 -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr -gencode=arch=compute_89,code=sm_89 --compiler-options '-fPIC' -O3 --use_fast_math -std=c++17
cuda_post_cflags = 
cuda_dlink_post_cflags = 
ldflags = -shared -L/home/kbuser/projects/KernelBench-0/.venv/lib/python3.10/site-packages/torch/lib -lc10 -lc10_cuda -ltorch_cpu -ltorch_cuda -ltorch -ltorch_python -L/usr/local/cuda/lib64 -lcudart

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags



rule link
  command = $cxx $in $ldflags -o $out

build main.o: compile /mnt/d/doctor_learning/Academic_Project/paper_1/MutaKernel/cuda_extensions/main.cpp
build cuda.cuda.o: cuda_compile /mnt/d/doctor_learning/Academic_Project/paper_1/MutaKernel/cuda_extensions/cuda.cu



build log_softmax_cuda_cfgstress_mut_8efaa987b5.so: link main.o cuda.cuda.o

default log_softmax_cuda_cfgstress_mut_8efaa987b5.so
